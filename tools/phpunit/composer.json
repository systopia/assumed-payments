{
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/systopia/civicrm-test-fixtures.git"
    }
  ],
  "require": {
    "symfony/phpunit-bridge": "^7",
    "systopia/civicrm-test-fixtures": "0.1.0"
  },
  "scripts": {
    "post-install-cmd": [
      "@php vendor/bin/simple-phpunit install --configuration ../../phpunit.xml.dist"
